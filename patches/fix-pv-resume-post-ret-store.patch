--- a/drivers/xen/manage.c	2026-03-26 12:12:06.684612382 +0000
+++ b/drivers/xen/manage.c	2026-03-26 13:34:46.079690843 +0000
@@ -11,6 +11,17 @@
 #include <linux/reboot.h>
 #include <linux/sysrq.h>
 #include <linux/stop_machine.h>
+
+/*
+ * Xen PV restore workaround: after HYPERVISOR_suspend returns,
+ * the first caller-side execution path is unstable unless a store
+ * to a kernel data page occurs before the next function call.
+ * Pre-RET stores inside the hypercall return stub are insufficient.
+ * This page-aligned buffer provides the store target.
+ * See docs/plans/workspace-save-restore/13-clean-experiment-results.md
+ */
+static unsigned long xen_pv_resume_fence[PAGE_SIZE / sizeof(unsigned long)]
+	__aligned(PAGE_SIZE);
 #include <linux/suspend.h>
 #include <linux/freezer.h>
 #include <linux/syscore_ops.h>
@@ -75,6 +86,9 @@
                                            ? virt_to_gfn(xen_start_info)
                                            : 0);
 
+	/* Xen PV restore workaround: post-RET store (see above) */
+	WRITE_ONCE(xen_pv_resume_fence[0], 1);
+
 	xen_arch_post_suspend(si->cancelled);
 	xen_manage_runstate_time(si->cancelled ? 1 : 0);
 	gnttab_resume();
